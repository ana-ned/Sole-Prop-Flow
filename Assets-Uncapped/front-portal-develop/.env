# =====================================================================
# SAFE SANDBOX CONFIG — committed on purpose. Contains NO real secrets.
# =====================================================================
# This is the default config every teammate gets on clone. It runs the
# app in prototype (sandbox) mode and points every endpoint at a dead
# local port (127.0.0.1:9) so any stray network call fails instantly and
# locally — it can never reach a live Uncapped server.
#
# You do NOT need to edit this or add any other file to run the
# prototypes. Just `pnpm install` then `pnpm dev`.
# =====================================================================

REACT_APP_API_URL=http://127.0.0.1:9/blocked
REACT_APP_AUTH0_DOMAIN=127.0.0.1.invalid
REACT_APP_AUTH0_CLIENT_ID=disabled-prototype-mode
REACT_APP_AUTH0_AUDIENCE=http://127.0.0.1.invalid/api
REACT_APP_UNLEASH_URL=http://127.0.0.1:9/blocked
REACT_APP_UNLEASH_CLIENT_KEY=disabled-prototype-mode
REACT_APP_GOOGLE_PLACES_API_KEY=disabled
REACT_APP_VERSION=prototype
REACT_APP_MSW_ENABLED=true
REACT_APP_PROTOTYPE_MODE=true
